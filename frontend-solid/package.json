{
  "name": "frontend-solid",
  "private": true,
  "version": "5.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\" \"e2e/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.0",
    "@solidjs/router": "^0.15.0",
    "axios": "^1.8.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.0",
    "highlight.js": "^11.11.0",
    "marked": "^15.0.0",
    "solid-icons": "^1.1.0",
    "solid-js": "^1.9.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22.13.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "axe-core": "^4.11.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-solid": "^0.14.0",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  }
}
